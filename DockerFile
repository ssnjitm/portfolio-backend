# Use a lightweight Node image
FROM node:18-slim

# Create a non-root user for security (HF requirement for some features)
RUN useradd -m -u 1000 user
USER user
ENV HOME=/home/user \
    PATH=/home/user/.local/bin:$PATH

# Set working directory
WORKDIR $HOME/app

# Copy package files first (to leverage Docker caching)
COPY --chown=user package*.json ./
RUN npm install

# Copy the rest of your application
COPY --chown=user . .

# Match the HF default port
EXPOSE 7860

# Start the server
CMD ["node", "index.js"]